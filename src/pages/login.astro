---
import Layout from '../layouts/Layout.astro';
import LogoWithBackground from '../icons/logo-with-green-background.svg?raw';
---

<Layout title="Sim8085 - Login" showActions={false} fullwidth noHeader noFooter fullHeight>
    <div class="bg-main-background" x-data="authForm">
        <div class="flex min-h-[100vh] flex-col justify-center py-12 sm:px-6 lg:px-8">
            <div class="mb-8 mx-auto text-center flex items-center w-16 h-16">
                <Fragment set:html={LogoWithBackground} />
            </div>
            <div class="text-center sm:mx-auto sm:w-full sm:max-w-md">
                <h1 class="text-3xl font-extrabold text-active-foreground">
                    <span x-show="!isSignup">Login to Sim8085</span>
                    <span x-show="isSignup">Create Account</span>
                </h1>
                <p class="mt-4 text-secondary-foreground">
                    <span x-show="!isSignup">Enter your username and password to continue.</span>
                    <span x-show="isSignup">Enter a username and password to create a new account.</span>
                </p>
            </div>
            <div class="mt-4 sm:mx-auto sm:w-full sm:max-w-md">
                <div class="px-4 pb-4 pt-8 sm:rounded-lg sm:px-10 sm:pb-6 sm:shadow">
                    <div class="flex flex-col gap-4">
                        <div x-show="errorMessage" class="mb-4 p-3 bg-red-500/10 border border-red-500 rounded text-red-foreground text-sm">
                            <span x-text="errorMessage"></span>
                        </div>
                        <div>
                            <label for="username" class="block text-sm font-medium text-primary-foreground">Username</label>
                            <input
                                x-model="username"
                                id="username"
                                type="text"
                                placeholder="Enter your username"
                                class="mt-1 w-full px-3 py-2 border border-inactive-border rounded-md bg-secondary-background text-primary-foreground placeholder-gray-400 focus:outline-none focus:border-terminal focus:ring-1 focus:ring-terminal"
                                :disabled="isLoading"
                            />
                        </div>
                        <div>
                            <label for="password" class="block text-sm font-medium text-primary-foreground">Password</label>
                            <input
                                x-model="password"
                                id="password"
                                type="password"
                                placeholder="Enter your password"
                                class="mt-1 w-full px-3 py-2 border border-inactive-border rounded-md bg-secondary-background text-primary-foreground placeholder-gray-400 focus:outline-none focus:border-terminal focus:ring-1 focus:ring-terminal"
                                :disabled="isLoading"
                                @keydown.enter="submitForm"
                            />
                        </div>
                        <button
                            type="button"
                            @click="submitForm"
                            :disabled="isLoading"
                            class="w-full px-4 py-2 rounded-md border border-inactive-border bg-secondary-background hover:bg-main-background disabled:hover:bg-secondary-background text-sm font-medium text-primary-foreground disabled:cursor-wait disabled:opacity-50">
                            <span x-text="isLoading ? 'Processing...' : (isSignup ? 'Create Account' : 'Login')">Login</span>
                        </button>
                        <div class="flex items-center gap-2 py-2">
                            <span class="h-px flex-1 bg-secondary-background"></span>
                            <span class="shrink-0 text-secondary-foreground text-sm">OR</span>
                            <span class="h-px flex-1 bg-secondary-background"></span>
                        </div>
                        <button
                            type="button"
                            @click="toggleSignup"
                            :disabled="isLoading"
                            class="w-full px-4 py-2 rounded-md border border-inactive-border bg-secondary-background hover:bg-main-background disabled:hover:bg-secondary-background text-sm font-medium text-primary-foreground disabled:cursor-wait disabled:opacity-50">
                            <span x-text="isSignup ? 'Back to Login' : 'Create New Account'">Create New Account</span>
                        </button>
                        <a href="/"
                            class="inline-flex gap-2 w-full items-center justify-center px-4 py-2 text-sm font-medium text-secondary-foreground disabled:cursor-wait disabled:opacity-50"
                            :class="isLoading && 'opacity-50 cursor-not-allowed'"
                            :style="isLoading && 'pointer-events: none'"
                        >
                            Continue without Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
import Alpine from 'alpinejs';

document.addEventListener('alpine:init', () => {
    Alpine.data('authForm', () => ({
        username: '',
        password: '',
        isLoading: false,
        isSignup: false,
        errorMessage: null,

        toggleSignup() {
            this.isSignup = !this.isSignup;
            this.errorMessage = null;
        },

        async submitForm() {
            if (this.isSignup) {
                await this.register();
            } else {
                await this.login();
            }
        },

        async login() {
            if (!this.username.trim() || !this.password.trim()) {
                this.errorMessage = 'Please enter both username and password.';
                return;
            }

            this.isLoading = true;
            this.errorMessage = null;

            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: this.username, password: this.password })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Login failed');
                }

                // Store session and redirect
                localStorage.setItem('authToken', data.token);
                window.location.href = '/';
            } catch (error) {
                this.errorMessage = error.message;
                this.isLoading = false;
            }
        },

        async register() {
            if (!this.username.trim() || !this.password.trim()) {
                this.errorMessage = 'Please enter both username and password.';
                return;
            }

            if (this.username.length < 3) {
                this.errorMessage = 'Username must be at least 3 characters.';
                return;
            }

            if (this.password.length < 6) {
                this.errorMessage = 'Password must be at least 6 characters.';
                return;
            }

            this.isLoading = true;
            this.errorMessage = null;

            try {
                const response = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: this.username, password: this.password })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Registration failed');
                }

                // Store session and redirect
                localStorage.setItem('authToken', data.token);
                window.location.href = '/';
            } catch (error) {
                this.errorMessage = error.message;
                this.isLoading = false;
            }
        }
    }));
});
</script>
